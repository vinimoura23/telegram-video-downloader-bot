# Obrigatorio
TELEGRAM_BOT_TOKEN=coloque_seu_token_aqui

# Necessario apenas para modo local
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# 0 = API publica do Telegram
# 1 = servidor Bot API local gerenciado pelo bot
TELEGRAM_LOCAL_SERVER_ENABLED=1
TELEGRAM_LOCAL_API_URL=http://127.0.0.1:8081
TELEGRAM_LOCAL_SERVER_TIMEOUT=180

# Opcional: forca rebuild da imagem Docker do servidor local
TELEGRAM_LOCAL_SERVER_FORCE_REBUILD=0
